{
    "name":  "jinnsp-android",
    "version":  "0.1.0",
    "private":  true,
    "description":  "JinnSP Android app packaged with Capacitor",
    "type":  "module",
    "scripts":  {
                    "build":  "node scripts/build-android.mjs",
                    "sync":  "pnpm run build:android \u0026\u0026 cap sync android",
                    "open:android":  "cap open android",
                    "apk:debug":  "pnpm run sync \u0026\u0026 cd android \u0026\u0026 gradlew.bat assembleDebug",
                    "build:android":  "node scripts/build-android.mjs",
                    "build:web":  "node scripts/build-web.mjs"
                },
    "dependencies":  {
                         "@capacitor/android":  "^7.4.3",
                         "@capacitor/app":  "^7.0.2",
                         "@capacitor/core":  "^7.4.3",
                         "@capacitor/preferences":  "^7.0.2"
                     },
    "devDependencies":  {
                            "@capacitor/cli":  "^7.4.3"
                        }
}
